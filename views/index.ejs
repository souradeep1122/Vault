<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vault — Secure Document Storage</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.2.0/crypto-js.min.js"></script>
<style>
:root {
  --bg:#0c0c0f; --surface:#131318; --surface2:#1a1a22; --surface3:#22222e;
  --border:rgba(255,255,255,0.07); --border2:rgba(255,255,255,0.12);
  --accent:#c8f04a; --accent2:#a8d63a;
  --text:#f0f0f5; --text2:#9090a8; --text3:#606078;
  --danger:#ff4f4f; --success:#4fcc8a; --warn:#f0a030;
  --radius:16px; --radius-sm:10px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden}

/* ── LOGIN ── */
#login-screen{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;
  background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(200,240,74,0.08) 0%,transparent 70%)}
.login-card{width:100%;max-width:400px;background:var(--surface);border:1px solid var(--border2);
  border-radius:24px;padding:48px 40px;position:relative;overflow:hidden}
.login-logo{font-family:'Syne',sans-serif;font-size:28px;font-weight:800;letter-spacing:-1px;margin-bottom:6px}
.login-logo span{color:var(--accent)}
.login-subtitle{color:var(--text3);font-size:13px;margin-bottom:36px}
.field-label{font-size:11px;font-weight:500;letter-spacing:1.2px;text-transform:uppercase;color:var(--text3);margin-bottom:8px;display:block}
.input-wrap{position:relative;margin-bottom:20px}
.input-wrap input{width:100%;background:var(--surface2);border:1px solid var(--border2);border-radius:var(--radius-sm);
  padding:14px 48px 14px 16px;font-family:'DM Sans',sans-serif;font-size:15px;color:var(--text);outline:none;transition:border-color 0.2s}
.input-wrap input:focus{border-color:var(--accent)}
.eye-btn{position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;
  color:var(--text3);cursor:pointer;font-size:16px;padding:4px}
.btn-primary{width:100%;background:var(--accent);color:#0c0c0f;border:none;border-radius:var(--radius-sm);
  padding:14px;font-family:'Syne',sans-serif;font-size:15px;font-weight:700;cursor:pointer;
  transition:background 0.2s,transform 0.1s}

/* ── APP ── */
#app{display:none;min-height:100vh;flex-direction:column}
nav{display:flex;align-items:center;justify-content:space-between;padding:18px 24px;background:var(--surface);
  border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100}
.nav-logo{font-family:'Syne',sans-serif;font-size:20px;font-weight:800;letter-spacing:-0.5px}
.nav-logo span{color:var(--accent)}
.nav-right{display:flex;gap:10px;align-items:center}
.btn-ghost{background:none;border:1px solid var(--border2);border-radius:var(--radius-sm);padding:8px 16px;
  color:var(--text2);font-family:'DM Sans',sans-serif;font-size:13px;cursor:pointer;transition:all 0.2s}
.btn-ghost:hover{background:var(--surface2);color:var(--text)}
.btn-accent{background:var(--accent);border:none;border-radius:var(--radius-sm);padding:9px 18px;
  color:#0c0c0f;font-family:'Syne',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:background 0.2s}
.btn-accent:hover{background:var(--accent2)}
main{flex:1;padding:32px 24px;max-width:1200px;margin:0 auto;width:100%}
.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px}
.section-title{font-family:'Syne',sans-serif;font-size:22px;font-weight:700;letter-spacing:-0.5px}

/* ── PEOPLE ── */
.people-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px}
.person-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
  padding:24px;cursor:pointer;transition:border-color 0.2s,transform 0.15s,background 0.2s;position:relative;overflow:hidden}
.person-card:hover{border-color:var(--border2);background:var(--surface2);transform:translateY(-2px)}
.person-avatar{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--accent),#5bc8af);
  display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;
  font-size:18px;font-weight:800;color:#0c0c0f;margin-bottom:14px;background-size:cover;background-position:center}
.person-name{font-family:'Syne',sans-serif;font-size:17px;font-weight:700;margin-bottom:4px}
.person-meta{font-size:13px;color:var(--text3)}
.person-actions{display:flex;gap:8px;margin-top:18px}
.btn-sm{flex:1;padding:8px;border-radius:8px;font-size:12px;font-weight:500;cursor:pointer;
  transition:all 0.2s;text-align:center;font-family:'DM Sans',sans-serif;border:none}
.btn-sm-primary{background:rgba(200,240,74,0.12);color:var(--accent);border:1px solid rgba(200,240,74,0.2)!important}
.btn-sm-primary:hover{background:rgba(200,240,74,0.22)}
.btn-sm-danger{background:rgba(255,79,79,0.08);color:var(--danger);border:1px solid rgba(255,79,79,0.15)!important}
.btn-sm-danger:hover{background:rgba(255,79,79,0.18)}
.add-person-card{background:transparent;border:2px dashed var(--border2);border-radius:var(--radius);
  padding:24px;cursor:pointer;transition:all 0.2s;display:flex;align-items:center;
  justify-content:center;gap:10px;color:var(--text3);font-size:14px;font-weight:500;min-height:160px}
.add-person-card:hover{border-color:var(--accent);color:var(--accent);background:rgba(200,240,74,0.03)}

/* ── DOCUMENTS VIEW ── */
#doc-section{display:none}
.back-btn{display:flex;align-items:center;gap:8px;background:none;border:1px solid var(--border2);
  border-radius:var(--radius-sm);padding:8px 14px;color:var(--text2);font-size:13px;cursor:pointer;
  margin-bottom:24px;transition:all 0.2s;font-family:'DM Sans',sans-serif}
.back-btn:hover{background:var(--surface2);color:var(--text)}
.doc-type-tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:24px}
.tab{padding:7px 16px;border-radius:100px;border:1px solid var(--border2);background:none;
  color:var(--text3);font-size:12px;font-weight:500;cursor:pointer;transition:all 0.2s;font-family:'DM Sans',sans-serif}
.tab:hover{color:var(--text2);background:var(--surface2)}
.tab.active{background:var(--accent);color:#0c0c0f;border-color:var(--accent);font-weight:700}
.docs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:20px}

/* ── DOC CARD ── */
.doc-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
  overflow:hidden;display:flex;flex-direction:column;transition:border-color 0.2s,transform 0.15s}
.doc-card:hover{border-color:var(--border2);transform:translateY(-2px)}
.doc-preview-wrap{width:100%;height:180px;overflow:hidden;background:var(--surface2);
  display:flex;align-items:center;justify-content:center;cursor:zoom-in;position:relative}
.doc-preview-wrap img{width:100%;height:100%;object-fit:cover;transition:opacity 0.25s}
.doc-info{padding:16px;display:flex;flex-direction:column;gap:11px;flex:1}
.doc-top-row{display:flex;align-items:flex-start;justify-content:space-between;gap:8px}
.doc-type-badge{display:inline-block;padding:3px 10px;border-radius:100px;background:rgba(200,240,74,0.1);
  color:var(--accent);font-size:10px;font-weight:600;letter-spacing:0.8px;text-transform:uppercase}
.btn-del-doc{background:none;border:none;color:var(--danger);cursor:pointer;font-size:16px}
.doc-name{font-family:'Syne',sans-serif;font-size:14px;font-weight:700;line-height:1.3}
.doc-date{font-size:11px;color:var(--text3)}

/* ── SIZE ROW ── */
.size-row{display:flex;align-items:center;gap:8px;background:var(--surface2);border-radius:10px;padding:10px 12px}
.size-labels{display:flex;flex-direction:column;gap:2px;flex:1;min-width:0}
.size-orig{font-size:10px;color:var(--text3);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.size-new{font-size:11px;font-weight:500;color:var(--text2);transition:color 0.3s;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.size-new.compressed{color:var(--success)}
.size-delta{font-size:10px;font-weight:700;letter-spacing:0.2px;padding:3px 8px;border-radius:100px;
  background:rgba(144,144,168,0.12);color:var(--text3);white-space:nowrap;flex-shrink:0;transition:all 0.25s}
.size-delta.saved{background:rgba(79,204,138,0.12);color:var(--success)}

/* ── RESIZE CONTROL ── */
.resize-section{display:flex;flex-direction:column;gap:7px}
.resize-header{display:flex;align-items:center;justify-content:space-between}
.resize-label{font-size:11px;color:var(--text3);font-weight:500;letter-spacing:0.4px}
.resize-pct{font-family:'Syne',sans-serif;font-size:14px;font-weight:800;color:var(--accent)}

input[type=range].rslider{
  -webkit-appearance:none;appearance:none;width:100%;height:4px;border-radius:2px;
  outline:none;cursor:pointer;border:none;background:var(--surface3);
}
input[type=range].rslider::-webkit-slider-thumb{
  -webkit-appearance:none;appearance:none;width:17px;height:17px;border-radius:50%;
  background:var(--accent);cursor:pointer;box-shadow:0 0 0 3px rgba(200,240,74,0.18);
}
.resize-ticks{display:flex;justify-content:space-between;padding:0 2px}
.resize-tick{font-size:9px;color:var(--text3)}

/* ── DOWNLOAD BUTTONS ── */
.doc-dl-row{display:flex;gap:7px}
.btn-dl{flex:1;padding:9px 6px;border-radius:8px;font-size:11px;font-weight:600;cursor:pointer;
  transition:all 0.2s;text-align:center;border:none;font-family:'DM Sans',sans-serif}
.btn-dl-pdf{background:rgba(255,255,255,0.05);color:var(--text2);border:1px solid var(--border2)!important}
.btn-dl-jpg{background:rgba(200,240,74,0.09);color:var(--accent);border:1px solid rgba(200,240,74,0.2)!important}
.btn-dl:disabled{opacity:0.5;cursor:not-allowed}

/* ── MODALS ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.72);backdrop-filter:blur(7px);
  z-index:200;display:none;align-items:center;justify-content:center;padding:20px}
.modal-overlay.open{display:flex}
.modal{background:var(--surface);border:1px solid var(--border2);border-radius:20px;padding:32px;
  width:100%;max-width:460px;position:relative;max-height:90vh;overflow-y:auto}
.modal-title{font-family:'Syne',sans-serif;font-size:20px;font-weight:700;margin-bottom:24px}
.modal-input{width:100%;background:var(--surface2);border:1px solid var(--border2);border-radius:var(--radius-sm);
  padding:12px 16px;font-family:'DM Sans',sans-serif;font-size:14px;color:var(--text);outline:none;margin-bottom:16px}

/* ── FILE CHOOSE BUTTON ── */
.file-choose-btn{width:100%;background:var(--surface2);border:2px dashed var(--border2);
  border-radius:var(--radius-sm);padding:16px;color:var(--text3);font-family:'DM Sans',sans-serif;
  font-size:14px;cursor:pointer;margin-bottom:12px;transition:border-color 0.2s,color 0.2s;text-align:center;display:block}
.file-choose-btn:hover,.file-choose-btn:active{border-color:var(--accent);color:var(--accent)}
.file-chosen{border-color:var(--success)!important;color:var(--success)!important;border-style:solid!important}

/* ── UPLOAD PROGRESS ── */
.upload-progress-wrap{display:none;margin-bottom:14px}
.upload-progress-bar{height:5px;background:var(--surface3);border-radius:4px;overflow:hidden}
.upload-progress-fill{height:100%;background:var(--accent);border-radius:4px;width:0%;transition:width 0.25s ease}
.upload-progress-text{font-size:11px;color:var(--text3);margin-top:6px;text-align:center}

#toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(100px);
  background:var(--surface2);border:1px solid var(--border2);border-radius:100px;
  padding:12px 20px;font-size:13px;color:var(--text);z-index:999;
  transition:transform 0.3s ease;white-space:nowrap;max-width:92vw;overflow:hidden;text-overflow:ellipsis}
#toast.show{transform:translateX(-50%) translateY(0)}
#toast.success{border-color:var(--success);color:var(--success)}
#toast.error{border-color:var(--danger);color:var(--danger)}

#lightbox{position:fixed;inset:0;background:rgba(0,0,0,0.93);z-index:300;
  display:none;align-items:center;justify-content:center;padding:20px}
#lightbox.open{display:flex}
#lightbox img{max-width:100%;max-height:90vh;border-radius:12px;object-fit:contain}
</style>
</head>
<body>

<div id="login-screen">
  <div class="login-card">
    <div class="login-logo">Vault<span>.</span></div>
    <p class="login-subtitle">Your encrypted document storage</p>
    <label class="field-label">Access Password</label>
    <div class="input-wrap">
      <input type="password" id="pwd-input" placeholder="Enter password" onkeydown="if(event.key==='Enter') doLogin()">
      <button class="eye-btn" onclick="togglePwd()">👁</button>
    </div>
    <button class="btn-primary" onclick="doLogin()">Unlock Vault</button>
    <div id="login-err" style="color:var(--danger);font-size:13px;margin-top:12px;display:none">⚠ Incorrect password</div>
  </div>
</div>

<div id="app">
  <nav>
    <div class="nav-logo">Vault<span>.</span></div>
    <div class="nav-right">
      <button class="btn-ghost" onclick="doLogout()">⬡ Lock</button>
    </div>
  </nav>
  <main>
    <div id="people-section">
      <div class="section-header">
        <div class="section-title">Document Owners</div>
        <button class="btn-accent" onclick="openModal('modal-person')">+ Add Person</button>
      </div>
      <div class="people-grid" id="people-grid"></div>
    </div>

    <div id="doc-section">
      <button class="back-btn" onclick="backToPeople()">← Back</button>
      <div class="section-header">
        <div>
          <div class="section-title" id="doc-section-name"></div>
          <div style="color:var(--text3);font-size:13px;margin-top:2px" id="doc-count-label"></div>
        </div>
        <button class="btn-accent" onclick="openAddDoc()">+ Add Document</button>
      </div>
      <div class="doc-type-tabs" id="doc-tabs"></div>
      <div class="docs-grid" id="docs-grid"></div>
    </div>
  </main>
</div>

<!-- PERSON MODAL -->
<div class="modal-overlay" id="modal-person">
  <div class="modal">
    <button style="float:right;cursor:pointer;background:none;border:none;color:var(--text3)" onclick="closeModal('modal-person')">✕</button>
    <div class="modal-title">New Person</div>
    <label class="field-label">Full Name</label>
    <input class="modal-input" id="person-name-input" placeholder="e.g. Rahul Sharma" type="text" onkeydown="if(event.key==='Enter') addPerson()">
    <button class="btn-primary" onclick="addPerson()">Add Person</button>
  </div>
</div>

<!-- DOCUMENT UPLOAD MODAL -->
<div class="modal-overlay" id="modal-doc">
  <div class="modal">
    <button style="float:right;cursor:pointer;background:none;border:none;color:var(--text3)" onclick="closeModal('modal-doc')">✕</button>
    <div class="modal-title">Upload Document</div>
    <label class="field-label">Type</label>
    <select class="modal-input" id="doc-type-select" onchange="toggleOtherInput()">
      <option value="">— Select Type —</option>
      <option>Aadhaar Card</option><option>PAN Card</option><option>Passport</option>
      <option>Driving Licence</option><option>Photo</option><option value="Other">Other</option>
    </select>
    <input class="modal-input" id="doc-type-other" placeholder="Specify Type" style="display:none">

    <input type="file" id="file-input" style="display:none"
      accept="image/*,application/pdf,.pdf,.jpg,.jpeg,.png,.heic,.heif"
      onchange="onFileSelect(event)">

    <button class="file-choose-btn" id="file-choose-btn"
      onclick="document.getElementById('file-input').click()">
      📎 Choose File (Image or PDF)
    </button>

    <div id="upload-selected" style="font-size:12px;color:var(--success);margin-bottom:12px;display:none"></div>

    <div class="upload-progress-wrap" id="upload-progress-wrap">
      <div class="upload-progress-bar">
        <div class="upload-progress-fill" id="upload-progress-fill"></div>
      </div>
      <div class="upload-progress-text" id="upload-progress-text">Uploading…</div>
    </div>

    <button class="btn-primary" id="upload-btn" onclick="uploadDocument()">Process & Save</button>
  </div>
</div>

<!-- CONFIRM DIALOG -->
<div class="modal-overlay" id="confirm-dialog">
  <div class="modal">
    <div class="modal-title" id="confirm-title">Confirm Delete</div>
    <div id="confirm-msg" style="margin-bottom:24px;color:var(--text2)"></div>
    <div style="display:flex;gap:10px">
      <button class="btn-ghost" style="flex:1" onclick="closeModal('confirm-dialog')">Cancel</button>
      <button class="btn-sm btn-sm-danger" style="flex:1" id="confirm-ok-btn">Delete</button>
    </div>
  </div>
</div>

<div id="lightbox" onclick="this.classList.remove('open')">
  <img id="lightbox-img" src="" crossorigin="anonymous">
</div>
<div id="toast"></div>

<script>
const API_BASE = "/api";
/**
 * The secret is now managed via environment variables.
 * In a production build, this is injected via a build tool (like Vite/Webpack) or 
 * provided by the server environment. 
 */
const SECRET = '1';

let db = { people: [] };
let currentPersonIdx = null;
let activeTab = 'All';
let selectedFile = null;
const cardState = {};

let wakeLock = null;

pdfjsLib.GlobalWorkerOptions.workerSrc =
  'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

// ═══════════════════════════════════════════════════════
// UTILS
// ═══════════════════════════════════════════════════════
function fmtBytes(b) {
  if (!b || b <= 0) return 'Secure Link';
  if (b < 1024) return b + ' B';
  if (b < 1048576) return (b / 1024).toFixed(1) + ' KB';
  return (b / 1048576).toFixed(2) + ' MB';
}

function escHtml(str) {
  return (str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function updateSliderFill(slider, pct) {
  const fillPct = ((pct - 10) / 90 * 100).toFixed(1);
  slider.style.background =
    `linear-gradient(to right, var(--accent) ${fillPct}%, var(--surface3) ${fillPct}%)`;
}

function showToast(msg, type) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'show' + (type ? ' ' + type : '');
  clearTimeout(t._t);
  t._t = setTimeout(() => { t.className = ''; }, 4000);
}

// ═══════════════════════════════════════════════════════
// WAKE LOCK
// ═══════════════════════════════════════════════════════
async function acquireWakeLock() {
  try {
    if ('wakeLock' in navigator) wakeLock = await navigator.wakeLock.request('screen');
  } catch (e) { /* not critical */ }
}
async function releaseWakeLock() {
  try { if (wakeLock) { await wakeLock.release(); wakeLock = null; } } catch {}
}
document.addEventListener('visibilitychange', async () => {
  if (wakeLock !== null && document.visibilityState === 'visible') await acquireWakeLock();
});

// ═══════════════════════════════════════════════════════
// XHR-based upload
// ═══════════════════════════════════════════════════════
function xhrUpload(url, formData, onProgress) {
  return new Promise((resolve, reject) => {
    const xhr = new XMLHttpRequest();

    xhr.upload.addEventListener('progress', (e) => {
      if (e.lengthComputable) {
        const pct = Math.round((e.loaded / e.total) * 90);
        onProgress(pct, `Uploading… ${pct}%`);
      }
    });

    xhr.upload.addEventListener('load', () => onProgress(93, 'Processing on server…'));

    xhr.addEventListener('load', () => {
      if (xhr.status >= 200 && xhr.status < 300) {
        onProgress(100, 'Done!');
        try { resolve(JSON.parse(xhr.responseText)); } catch { resolve({}); }
      } else {
        let errMsg = `Server error ${xhr.status}`;
        try {
          const r = JSON.parse(xhr.responseText);
          if (r.message || r.error) errMsg = r.message || r.error;
        } catch {}
        reject(new Error(errMsg));
      }
    });

    xhr.addEventListener('error',   () => reject(new Error('Network error — check your connection')));
    xhr.addEventListener('abort',   () => reject(new Error('Upload was cancelled')));

    xhr.timeout = 120000;
    xhr.addEventListener('timeout', () => reject(new Error('Upload timed out — try on Wi-Fi')));

    xhr.open('POST', url);
    xhr.send(formData);
  });
}

// ═══════════════════════════════════════════════════════
// IMAGE / PDF HELPERS
// ═══════════════════════════════════════════════════════
function resizeJpeg(src, pct) {
  return new Promise((resolve, reject) => {
    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.onload = () => {
      try {
        const s = pct / 100;
        const canvas = document.createElement('canvas');
        canvas.width  = Math.max(1, Math.round(img.naturalWidth  * s));
        canvas.height = Math.max(1, Math.round(img.naturalHeight * s));
        const ctx = canvas.getContext('2d');
        ctx.imageSmoothingEnabled = true;
        ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
        resolve(canvas.toDataURL('image/jpeg', 0.50 + s * 0.42));
      } catch (e) { reject(e); }
    };
    img.onerror = reject;
    img.src = src;
  });
}

function imageToDataUrl(src, pct) {
  return new Promise((resolve, reject) => {
    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.onload = () => {
      try {
        const s = pct / 100;
        const canvas = document.createElement('canvas');
        canvas.width  = Math.max(1, Math.round(img.naturalWidth  * s));
        canvas.height = Math.max(1, Math.round(img.naturalHeight * s));
        const ctx = canvas.getContext('2d');
        ctx.imageSmoothingEnabled = true;
        ctx.imageSmoothingQuality = 'high';
        ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
        resolve(canvas.toDataURL('image/jpeg', pct === 100 ? 0.95 : (0.50 + s * 0.42)));
      } catch (e) { reject(e); }
    };
    img.onerror = () => reject(new Error('Image load failed'));
    img.src = src;
  });
}

function jpegToPdfBlob(jpegDataUrl) {
  return new Promise((resolve, reject) => {
    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.onload = () => {
      try {
        const W = img.naturalWidth, H = img.naturalHeight;
        const imgBytes = (() => {
          const bin = atob(jpegDataUrl.split(',')[1]);
          const arr = new Uint8Array(bin.length);
          for (let i = 0; i < bin.length; i++) arr[i] = bin.charCodeAt(i);
          return arr;
        })();
        const enc = new TextEncoder();
        const parts = [], offs = [];
        const add = s => parts.push(enc.encode(s));
        const pos = () => parts.reduce((s, p) => s + p.byteLength, 0);
        add('%PDF-1.4\n%\xFF\xFF\xFF\xFF\n');
        offs[1]=pos(); add('1 0 obj\n<< /Type /Catalog /Pages 2 0 R >>\nendobj\n');
        offs[2]=pos(); add('2 0 obj\n<< /Type /Pages /Kids [3 0 R] /Count 1 >>\nendobj\n');
        offs[3]=pos(); add(`3 0 obj\n<< /Type /Page /Parent 2 0 R /MediaBox [0 0 ${W} ${H}]\n /Contents 4 0 R /Resources << /XObject << /Im0 5 0 R >> >> >>\nendobj\n`);
        const sc=`q ${W} 0 0 ${H} 0 0 cm /Im0 Do Q\n`;
        offs[4]=pos(); add(`4 0 obj\n<< /Length ${sc.length} >>\nstream\n${sc}endstream\nendobj\n`);
        offs[5]=pos(); add(`5 0 obj\n<< /Type /XObject /Subtype /Image /Width ${W} /Height ${H}\n /ColorSpace /DeviceRGB /BitsPerComponent 8\n /Filter /DCTDecode /Length ${imgBytes.byteLength} >>\nstream\n`);
        parts.push(imgBytes); add('\nendstream\nendobj\n');
        const xo=pos();
        let xr='xref\n0 6\n0000000000 65535 f \n';
        for(let i=1;i<=5;i++) xr+=offs[i].toString().padStart(10,'0')+' 00000 n \n';
        xr+=`trailer\n<< /Size 6 /Root 1 0 R >>\nstartxref\n${xo}\n%%EOF\n`;
        add(xr);
        const out=new Uint8Array(parts.reduce((s,p)=>s+p.byteLength,0));
        let p2=0; for(const p of parts){out.set(p,p2);p2+=p.byteLength;}
        resolve(new Blob([out],{type:'application/pdf'}));
      } catch(e){reject(e);}
    };
    img.onerror=reject;
    img.src=jpegDataUrl;
  });
}

function blobDownload(blobOrDataUrl, filename) {
  const a = document.createElement('a');
  if (typeof blobOrDataUrl === 'string') {
    a.href = blobOrDataUrl;
  } else {
    a.href = URL.createObjectURL(blobOrDataUrl);
    setTimeout(() => URL.revokeObjectURL(a.href), 5000);
  }
  a.download = filename;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
}

// ═══════════════════════════════════════════════════════
// FETCH PEOPLE & RENDER
// ═══════════════════════════════════════════════════════
async function fetchPeople() {
  try {
    const res = await fetch(`${API_BASE}/people`);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    db.people = await res.json();
    renderPeople();
  } catch (err) { showToast('Connection failed: ' + err.message, 'error'); }
}

function renderPeople() {
  const grid = document.getElementById('people-grid');
  grid.innerHTML = '';
  db.people.forEach((p, i) => {
    const photoDoc = (p.documents || []).find(d => d.type === 'Photo');
    const avatarStyle = photoDoc ? `background-image:url(${photoDoc.jpeg});` : '';
    const avatarContent = photoDoc ? '' : p.name[0].toUpperCase();
    const card = document.createElement('div');
    card.className = 'person-card';
    card.innerHTML = `
      <div class="person-avatar" style="${avatarStyle}">${avatarContent}</div>
      <div class="person-name">${escHtml(p.name)}</div>
      <div class="person-meta">${p.documents.length} files</div>
      <div class="person-actions">
        <button class="btn-sm btn-sm-primary" onclick="event.stopPropagation();openPersonDocs(${i})">View Documents</button>
        <button class="btn-sm btn-sm-danger"  onclick="event.stopPropagation();deletePerson('${p._id}')">Delete</button>
      </div>`;
    card.onclick = () => openPersonDocs(i);
    grid.appendChild(card);
  });
  const add = document.createElement('div');
  add.className = 'add-person-card';
  add.innerHTML = '+ Add Person';
  add.onclick = () => openModal('modal-person');
  grid.appendChild(add);
}

function renderDocs() {
  const p = db.people[currentPersonIdx];
  const filtered = activeTab === 'All' ? p.documents : p.documents.filter(d => d.type === activeTab);
  document.getElementById('doc-count-label').textContent = `${p.documents.length} files`;

  const tabsEl = document.getElementById('doc-tabs');
  tabsEl.innerHTML = '';
  ['All', ...new Set(p.documents.map(d => d.type))].forEach(t => {
    const btn = document.createElement('button');
    btn.className = `tab ${t === activeTab ? 'active' : ''}`;
    btn.textContent = t;
    btn.onclick = () => { activeTab = t; renderDocs(); };
    tabsEl.appendChild(btn);
  });

  const grid = document.getElementById('docs-grid');
  grid.innerHTML = '';
  filtered.forEach((doc, ri) => {
    const card = document.createElement('div');
    card.className = 'doc-card';
    card.innerHTML = `
      <div class="doc-preview-wrap" onclick="openLightbox('${doc.jpeg}')">
        <img src="${doc.jpeg}" crossorigin="anonymous" id="pi-${ri}">
      </div>
      <div class="doc-info">
        <div class="doc-top-row">
          <div class="doc-type-badge">${escHtml(doc.type)}</div>
          <button class="btn-del-doc" onclick="deleteDoc('${doc._id}')">🗑</button>
        </div>
        <div class="doc-name">${escHtml(doc.name)}</div>
        <div class="doc-date">${escHtml(doc.date)}</div>
        <div class="size-row">
          <div class="size-labels">
            <span class="size-orig">Original: ${fmtBytes(doc.size)}</span>
            <span class="size-new" id="sn-${ri}">Resized: Move slider</span>
          </div>
          <span class="size-delta" id="sd-${ri}">100%</span>
        </div>
        <div class="resize-section">
          <div class="resize-header">
            <span class="resize-label">Resize before download</span>
            <span class="resize-pct" id="rp-${ri}">100%</span>
          </div>
          <input type="range" class="rslider" id="rs-${ri}" min="10" max="100" step="5" value="100">
          <div class="resize-ticks"><span class="resize-tick">10%</span><span class="resize-tick">100%</span></div>
        </div>
        <div class="doc-dl-row">
          <button class="btn-dl btn-dl-pdf" id="btn-pdf-${ri}" onclick="dlResized(${ri},'pdf')">↓ PDF</button>
          <button class="btn-dl btn-dl-jpg" id="btn-jpg-${ri}" onclick="dlResized(${ri},'jpg')">↓ JPEG</button>
        </div>
      </div>`;
    grid.appendChild(card);
    const slider = card.querySelector('.rslider');
    slider.addEventListener('input', () => onSlider(ri, doc.size || 500000, slider));
    updateSliderFill(slider, 100);
  });
}

function onSlider(ri, origBytes, sliderEl) {
  const pct = parseInt(sliderEl.value);
  updateSliderFill(sliderEl, pct);
  if (!cardState[ri]) cardState[ri] = {};
  cardState[ri].pct = pct;
  document.getElementById(`rp-${ri}`).textContent = pct + '%';
  const snEl = document.getElementById(`sn-${ri}`);
  const sdEl = document.getElementById(`sd-${ri}`);
  if (pct === 100) {
    snEl.textContent = 'Original Scale'; snEl.className = 'size-new';
    sdEl.textContent = '100%'; sdEl.className = 'size-delta';
  } else {
    snEl.textContent = `Estimated: ${fmtBytes(Math.round(origBytes * pct / 100))}`;
    snEl.className = 'size-new compressed';
    sdEl.textContent = `−${100-pct}%`; sdEl.className = 'size-delta saved';
  }
  clearTimeout(cardState[ri].timer);
  cardState[ri].timer = setTimeout(async () => {
    const imgEl = document.getElementById(`pi-${ri}`);
    const orig = db.people[currentPersonIdx].documents[ri].jpeg;
    imgEl.style.opacity = '0.4';
    try {
      const resized = pct === 100 ? orig : await resizeJpeg(orig, pct);
      imgEl.src = resized;
      imgEl.style.opacity = '1';
      cardState[ri].cachedJpeg = resized;
    } catch { imgEl.style.opacity = '1'; }
  }, 300);
}

async function dlResized(ri, fmt) {
  const doc = db.people[currentPersonIdx].documents[ri];
  const state = cardState[ri] || {};
  const pct = state.pct || 100;
  const filename = doc.name + (pct < 100 ? `_${pct}pct` : '');
  const pdfBtn = document.getElementById(`btn-pdf-${ri}`);
  const jpgBtn = document.getElementById(`btn-jpg-${ri}`);
  if (pdfBtn) pdfBtn.disabled = true;
  if (jpgBtn) jpgBtn.disabled = true;
  showToast(fmt === 'pdf' ? 'Generating PDF…' : 'Preparing…', '');
  try {
    const jpegDataUrl = (pct === 100 && state.cachedJpeg)
      ? state.cachedJpeg
      : await imageToDataUrl(doc.jpeg, pct);
    if (!cardState[ri]) cardState[ri] = {};
    cardState[ri].cachedJpeg = jpegDataUrl;
    if (fmt === 'jpg') {
      blobDownload(jpegDataUrl, filename + '.jpg');
    } else {
      blobDownload(await jpegToPdfBlob(jpegDataUrl), filename + '.pdf');
    }
    showToast(fmt.toUpperCase() + ' saved ✓', 'success');
  } catch (err) {
    console.error(err);
    showToast('Download failed: ' + err.message, 'error');
  } finally {
    if (pdfBtn) pdfBtn.disabled = false;
    if (jpgBtn) jpgBtn.disabled = false;
  }
}

// ═══════════════════════════════════════════════════════
// ADD PERSON
// ═══════════════════════════════════════════════════════
async function addPerson() {
  const name = document.getElementById('person-name-input').value.trim();
  if (!name) return;
  try {
    const res = await fetch(`${API_BASE}/people`, {
      method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({name})
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    closeModal('modal-person');
    document.getElementById('person-name-input').value = '';
    fetchPeople();
  } catch (e) { showToast('Failed: ' + e.message, 'error'); }
}

// ═══════════════════════════════════════════════════════
// UPLOAD DOCUMENT
// ═══════════════════════════════════════════════════════
async function uploadDocument() {
  const sel = document.getElementById('doc-type-select');
  let type = sel.value === 'Other'
    ? document.getElementById('doc-type-other').value.trim()
    : sel.value;
  if (!type)         return showToast('Please select a document type', 'error');
  if (!selectedFile) return showToast('Please choose a file', 'error');

  const wrap  = document.getElementById('upload-progress-wrap');
  const fill  = document.getElementById('upload-progress-fill');
  const label = document.getElementById('upload-progress-text');
  wrap.style.display = 'block';
  fill.style.width = '0%';
  fill.style.background = 'var(--accent)';
  label.textContent = 'Starting…';

  const btn = document.getElementById('upload-btn');
  btn.disabled = true;
  btn.textContent = 'Uploading…';

  await acquireWakeLock();

  let fileToSend = selectedFile;
  if (!selectedFile.type || selectedFile.type === 'application/octet-stream') {
    const ext = selectedFile.name.split('.').pop().toLowerCase();
    const mimeMap = {
      pdf:'application/pdf', jpg:'image/jpeg', jpeg:'image/jpeg',
      png:'image/png', heic:'image/heic', heif:'image/heif', webp:'image/webp'
    };
    fileToSend = new File([selectedFile], selectedFile.name, {
      type: mimeMap[ext] || 'application/octet-stream'
    });
  }

  const formData = new FormData();
  formData.append('type', type);
  formData.append('name', selectedFile.name.replace(/\.[^/.]+$/, ''));
  formData.append('date', new Date().toLocaleDateString('en-IN'));
  formData.append('file', fileToSend);

  try {
    await xhrUpload(
      `${API_BASE}/documents/${db.people[currentPersonIdx]._id}`,
      formData,
      (pct, txt) => { fill.style.width = pct + '%'; label.textContent = txt; }
    );
    closeModal('modal-doc');
    resetUploadModal();
    showToast('Uploaded successfully ✓', 'success');
    await fetchPeople();
    setTimeout(() => {
      const idx = db.people.findIndex(p => p._id === db.people[currentPersonIdx]?._id);
      if (idx !== -1) openPersonDocs(idx);
    }, 400);
  } catch (e) {
    console.error('Upload error:', e);
    showToast(e.message || 'Upload failed', 'error');
    fill.style.background = 'var(--danger)';
    label.textContent = '⚠ ' + (e.message || 'Upload failed');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Process & Save';
    await releaseWakeLock();
    setTimeout(() => {
      wrap.style.display = 'none';
      fill.style.width = '0%';
      fill.style.background = 'var(--accent)';
    }, 2500);
  }
}

function resetUploadModal() {
  document.getElementById('doc-type-select').value = '';
  document.getElementById('doc-type-other').value = '';
  document.getElementById('doc-type-other').style.display = 'none';
  document.getElementById('upload-selected').style.display = 'none';
  document.getElementById('file-input').value = '';
  const cb = document.getElementById('file-choose-btn');
  cb.textContent = '📎 Choose File (Image or PDF)';
  cb.classList.remove('file-chosen');
  selectedFile = null;
}

// ═══════════════════════════════════════════════════════
// DELETE
// ═══════════════════════════════════════════════════════
async function deleteDoc(docId) {
  if (!confirm('Delete this document?')) return;
  try {
    await fetch(`${API_BASE}/documents/${db.people[currentPersonIdx]._id}/${docId}`, {method:'DELETE'});
    await fetchPeople();
    setTimeout(() => openPersonDocs(currentPersonIdx), 300);
  } catch (e) { showToast('Delete failed: ' + e.message, 'error'); }
}

async function deletePerson(id) {
  if (!confirm('Delete person and all their documents?')) return;
  try {
    await fetch(`${API_BASE}/people/${id}`, {method:'DELETE'});
    fetchPeople();
  } catch (e) { showToast('Delete failed: ' + e.message, 'error'); }
}

// ═══════════════════════════════════════════════════════
// UI HELPERS
// ═══════════════════════════════════════════════════════
function doLogin() {
  if (document.getElementById('pwd-input').value === SECRET) {
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('app').style.display = 'flex';
    document.getElementById('login-err').style.display = 'none';
    fetchPeople();
  } else {
    document.getElementById('login-err').style.display = 'block';
    document.getElementById('pwd-input').value = '';
  }
}
function doLogout()      { location.reload(); }
function openAddDoc()    { resetUploadModal(); openModal('modal-doc'); }
function backToPeople()  {
  document.getElementById('doc-section').style.display = 'none';
  document.getElementById('people-section').style.display = 'block';
  fetchPeople();
}
function openPersonDocs(idx) {
  currentPersonIdx = idx;
  document.getElementById('people-section').style.display = 'none';
  document.getElementById('doc-section').style.display = 'block';
  document.getElementById('doc-section-name').textContent = db.people[idx].name;
  renderDocs();
}
function openModal(id)  { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
function togglePwd()    { const i = document.getElementById('pwd-input'); i.type = i.type==='password'?'text':'password'; }
function toggleOtherInput() {
  document.getElementById('doc-type-other').style.display =
    document.getElementById('doc-type-select').value === 'Other' ? 'block' : 'none';
}
function onFileSelect(e) {
  selectedFile = e.target.files[0];
  if (!selectedFile) return;
  const name = selectedFile.name.length > 32
    ? selectedFile.name.substring(0, 30) + '…' : selectedFile.name;
  document.getElementById('upload-selected').textContent = `✓ ${name} (${fmtBytes(selectedFile.size)})`;
  document.getElementById('upload-selected').style.display = 'block';
  const cb = document.getElementById('file-choose-btn');
  cb.textContent = '✓ ' + name;
  cb.classList.add('file-chosen');
}
function openLightbox(src) {
  document.getElementById('lightbox-img').src = src;
  document.getElementById('lightbox').classList.add('open');
}
</script>
